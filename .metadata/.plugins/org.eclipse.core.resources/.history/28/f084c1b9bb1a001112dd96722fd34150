body{
font-family: Arial, sans-serif;
background:#f4f6f8;
text-align:center;
margin:0;
padding:0;
}

h2{
color:#2e7d32;
}

.container{
width:500px;
margin:auto;
margin-top:40px;
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

button{
background:#2e7d32;
color:white;
border:none;
padding:10px 20px;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#1b5e20;
}

input{
padding:8px;
margin:5px;
width:80%;
}

table{
margin:auto;
border-collapse:collapse;
width:60%;
}

th,td{
padding:10px;
border:1px solid #ddd;
}

th{
background:#2e7d32;
color:white;
}