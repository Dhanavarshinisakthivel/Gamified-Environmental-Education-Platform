<!DOCTYPE html>
<html>
<head>

<title>Eco Memory Game</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:"Segoe UI",sans-serif;
}

body{

height:100vh;

display:flex;
justify-content:center;
align-items:center;

background:linear-gradient(-45deg,#020617,#0f172a,#1e3a8a,#0f172a);
background-size:400% 400%;
animation:bgMove 12s infinite alternate;

color:white;

}

@keyframes bgMove{

0%{background-position:0% 50%}
100%{background-position:100% 50%}

}

/* Container */

.container{

width:900px;
padding:40px;

background:rgba(255,255,255,0.05);
backdrop-filter:blur(10px);

border-radius:20px;

box-shadow:0 20px 60px rgba(0,0,0,0.8);

text-align:center;

}

/* Title */

h1{

font-size:36px;
margin-bottom:10px;

background:linear-gradient(90deg,#60a5fa,#3b82f6);
-webkit-background-clip:text;
color:transparent;

}

/* Timer */

.timer{

display:inline-block;

padding:10px 25px;

margin-top:20px;
margin-bottom:40px;

border-radius:12px;

border:2px solid #3b82f6;

font-size:20px;

box-shadow:0 0 12px #3b82f6;

}

/* Grid */

.grid{

display:grid;

grid-template-columns:repeat(4,1fr);

gap:20px;

}

/* Card */

.card{

height:120px;

perspective:1000px;

cursor:pointer;

}

/* Inner */

.card-inner{

position:relative;

width:100%;
height:100%;

transform-style:preserve-3d;

transition:transform 0.6s;

}

.card.flip .card-inner{

transform:rotateY(180deg);

}

/* Front */

.card-front{

position:absolute;

width:100%;
height:100%;

display:flex;
align-items:center;
justify-content:center;

background:#2563eb;

border-radius:12px;

font-size:30px;

}

/* Back */

.card-back{

position:absolute;

width:100%;
height:100%;

display:flex;
align-items:center;
justify-content:center;

background:#111827;

border-radius:12px;

transform:rotateY(180deg);

font-size:18px;

font-weight:bold;

}

/* Popup */

.popup{

display:none;

position:fixed;

top:50%;
left:50%;

transform:translate(-50%,-50%);

background:#020617;

padding:40px;

border-radius:20px;

border:2px solid #3b82f6;

box-shadow:0 20px 60px rgba(0,0,0,0.9);

text-align:center;

}

button{

margin-top:15px;

padding:10px 25px;

border:none;

border-radius:10px;

background:#2563eb;

color:white;

cursor:pointer;

}

.star{

font-size:30px;
color:gold;

}

</style>

</head>

<body>

<div class="container">

<h1>Eco Memory Game</h1>

<p>Match environmental concepts</p>

<div class="timer">
Time Left : <span id="time">90</span>s
</div>

<div class="grid" id="gameBoard"></div>

</div>

<!-- START POPUP -->

<div id="startPopup" class="popup">

<h2>Eco Memory Game</h2>

<p>Match all pairs before the timer ends.</p>

<button onclick="startGame()">Start Game</button>

</div>

<!-- SUCCESS POPUP -->

<div id="successPopup" class="popup">

<h2>🎉 Congratulations!</h2>

<p>You completed the Eco Memory Game</p>

<div id="stars"></div>

<button onclick="goHome()">Back to Dashboard</button>

</div>

<script>

/* CARD DATA */

const icons=[
"🌳","🌳",
"🌎","🌎",
"☀","☀",
"💧","💧",
"🌱","🌱",
"♻","♻",
"🌬","🌬",
"🌿","🌿"
];

icons.sort(()=>Math.random()-0.5);

/* CREATE BOARD */

const board=document.getElementById("gameBoard");

icons.forEach(icon=>{

let card=document.createElement("div");
card.className="card";

card.innerHTML=`

<div class="card-inner">

<div class="card-front">🌍</div>

<div class="card-back">${icon}</div>

</div>

`;

board.appendChild(card);

});

/* GAME */

let flipped=[];
let matched=0;

document.querySelectorAll(".card").forEach(card=>{

card.addEventListener("click",()=>{

if(card.classList.contains("flip")) return;

card.classList.add("flip");

flipped.push(card);

if(flipped.length===2){

let a=flipped[0].querySelector(".card-back").textContent;
let b=flipped[1].querySelector(".card-back").textContent;

if(a===b){

matched++;

flipped=[];

if(matched===8){

clearInterval(timer);

showSuccess();

}

}else{

setTimeout(()=>{

flipped[0].classList.remove("flip");
flipped[1].classList.remove("flip");

flipped=[];

},900);

}

}

});

});

/* TIMER */

let time=90;
let timer;

window.onload=()=>{

document.getElementById("startPopup").style.display="block";

}

function startGame(){

document.getElementById("startPopup").style.display="none";

timer=setInterval(()=>{

time--;

document.getElementById("time").innerText=time;

if(time<=0){

clearInterval(timer);

alert("Time Up!");

location.reload();

}

},1000);

}

/* SUCCESS */

function showSuccess(){

document.getElementById("successPopup").style.display="block";

let starHTML="";

if(time>60) starHTML="⭐⭐⭐";
else if(time>30) starHTML="⭐⭐";
else starHTML="⭐";

document.getElementById("stars").innerHTML=starHTML;

}

function goHome(){

window.location.href="/home";

}

</script>

</body>

</html>