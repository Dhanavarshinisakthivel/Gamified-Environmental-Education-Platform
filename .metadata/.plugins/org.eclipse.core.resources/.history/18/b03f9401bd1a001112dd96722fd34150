/* General Page Styling */
body{
    font-family: "Segoe UI", Arial, sans-serif;
    background: linear-gradient(135deg,#e8f5e9,#f1f8e9);
    margin:0;
    padding:0;
    text-align:center;
}

/* Page Container */
.container{
    width:420px;
    margin:auto;
    margin-top:60px;
    background:white;
    padding:30px;
    border-radius:12px;
    box-shadow:0 8px 20px rgba(0,0,0,0.15);
}

/* Titles */
h1,h2,h3{
    color:#2e7d32;
}

/* Inputs */
input, select{
    width:90%;
    padding:10px;
    margin:8px 0;
    border-radius:6px;
    border:1px solid #ccc;
    font-size:14px;
}

/* Buttons */
button{
    background:#2e7d32;
    color:white;
    border:none;
    padding:10px 20px;
    margin-top:10px;
    border-radius:6px;
    cursor:pointer;
    font-size:15px;
    transition:0.3s;
}

button:hover{
    background:#1b5e20;
}

/* Links */
a{
    text-decoration:none;
    color:#2e7d32;
    font-weight:600;
}

a:hover{
    text-decoration:underline;
}

/* Quiz Question Card */
.question-card{
    background:#f9f9f9;
    padding:15px;
    border-radius:8px;
    margin-bottom:15px;
    text-align:left;
}

/* Leaderboard Table */
table{
    width:90%;
    margin:auto;
    border-collapse:collapse;
    margin-top:20px;
    background:white;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

th, td{
    padding:12px;
    border-bottom:1px solid #ddd;
}

th{
    background:#2e7d32;
    color:white;
}

tr:hover{
    background:#f1f8e9;
}

/* Result Page */
.score-box{
    font-size:24px;
    color:#1b5e20;
    font-weight:bold;
    margin:20px 0;
}

/* Eco Tips */
ul{
    text-align:left;
    padding-left:20px;
}